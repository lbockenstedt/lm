# Lab Manager Hub — environment configuration
# Copy to `.env` and fill in real values. NEVER commit `.env` (it is gitignored).

# ---------------------------------------------------------------------------
# CORS (opt-in)
# ---------------------------------------------------------------------------
# Comma-separated origins allowed to send credentialed cross-origin requests
# to the Hub API (e.g. https://labmgr.example.com,http://localhost:5173).
# Empty = no cross-origin credentialed access (same-origin still works).
LM_CORS_ORIGINS=

# ---------------------------------------------------------------------------
# Development backdoor (OFF by default — do NOT enable in production)
# ---------------------------------------------------------------------------
# Only set LM_DEV_MODE=1 in isolated lab environments, AND set LM_DEV_SECRET
# to a strong random value. When unset, the dev-secret auth fallback is fully
# disabled (fail-closed). Never reuse these in production.
# LM_DEV_MODE=1
# LM_DEV_SECRET=

# ---------------------------------------------------------------------------
# OPNsense spoke (set on the OPNsense spoke host, not the Hub)
# ---------------------------------------------------------------------------
# Set LM_OPNSENSE_INSECURE_TLS=1 ONLY for self-signed lab firewall certificates.
# Default (unset) enforces TLS verification. The Hub-level example is here for
# reference; deploy it on the opnsense spoke's systemd unit / .env.
# LM_OPNSENSE_INSECURE_TLS=1

# ---------------------------------------------------------------------------
# At-rest encryption key (REQUIRED, fail-closed)
# ---------------------------------------------------------------------------
# A Fernet key used to encrypt secrets/state at rest (hub_secret.json, keys.json,
# system.json, tenants.json). REQUIRED: if unset or invalid, the Hub will not start.
# Existing blobs encrypted with the legacy machine-id key remain decryptable
# (transparent migration on the same machine), but new writes require this key.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LM_FERNET_KEY=